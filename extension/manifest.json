{
    "manifest_version": 3,

    "name": "MailTracker",

    "description": "Track email opens directly from Gmail.",

    "version": "1.0.0",

    "permissions": [
        "storage"
    ],

    "host_permissions": [
        "https://mail.google.com/*",
        "http://localhost:3000/*"
    ],

    "background": {
        "service_worker": "background/background.js"
    },

    "content_scripts": [
        {
            "matches": [
                "https://mail.google.com/*"
            ],
            "js": [
                "gmail/compose.js",
                "gmail/observer.js"
            ],
            "run_at": "document_idle"
        }
    ],

    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "MailTracker"
    }
}